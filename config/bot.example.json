{
  "irc": {
    "host": "irc.rizon.net",
    "port": 6697,
    "tls": true,
    "nick": "Hexbot",
    "username": "hexbot",
    "realname": "HexBot IRC Bot",
    "channels": ["#hexbot", { "name": "#secret", "key": "password" }],
    "_comment_tls_verify": "tls_verify defaults to true (validates server cert). Set to false only for networks with self-signed certs — disables certificate validation",
    "_comment_tls_cert": "Optional: set tls_cert + tls_key and sasl_mechanism=EXTERNAL for CertFP auth (no password needed)"
  },
  "owner": {
    "handle": "admin",
    "hostmask": "*!yourident@your.host.here"
  },
  "identity": {
    "method": "hostmask",
    "require_acc_for": ["+o", "+n"]
  },
  "services": {
    "type": "anope",
    "nickserv": "NickServ",
    "password": "",
    "sasl": true,
    "sasl_mechanism": "PLAIN"
  },
  "database": "./data/hexbot.db",
  "pluginDir": "./plugins",
  "_comment_pluginsConfig": "pluginsConfig: path to plugins.json. Defaults to ./config/plugins.json. Useful for multi-bot setups.",
  "logging": {
    "level": "info",
    "mod_actions": true
  },
  "queue": {
    "rate": 1,
    "burst": 5
  },
  "flood": {
    "pub": { "count": 5, "window": 10 },
    "msg": { "count": 5, "window": 10 }
  },
  "dcc": {
    "enabled": false,
    "ip": "0.0.0.0",
    "port_range": [49152, 49171],
    "require_flags": "m",
    "max_sessions": 5,
    "idle_timeout_ms": 300000,
    "nickserv_verify": false
  },
  "proxy": {
    "enabled": false,
    "host": "127.0.0.1",
    "port": 9050
  },
  "botlink": {
    "enabled": false,
    "role": "leaf",
    "botname": "mybot",
    "hub": {
      "host": "192.168.1.10",
      "port": 5051
    },
    "listen": {
      "host": "0.0.0.0",
      "port": 5051
    },
    "password": "changeme-shared-secret",
    "reconnect_delay_ms": 5000,
    "reconnect_max_delay_ms": 60000,
    "max_leaves": 10,
    "sync_permissions": true,
    "sync_channel_state": true,
    "sync_bans": true,
    "ping_interval_ms": 30000,
    "link_timeout_ms": 90000
  },
  "chanmod": {
    "nick_recovery_password": ""
  },
  "quit_message": "HexBot",
  "_comment_channel_rejoin": "channel_rejoin_interval_ms: how often (ms) to check for missing channels and attempt rejoin. Default 30000. Set to 0 to disable.",
  "channel_rejoin_interval_ms": 30000
}
