{
  "irc": {
    "host": "irc.rizon.net",
    "port": 6697,
    "tls": true,
    "nick": "Hexbot",
    "username": "hexbot",
    "realname": "HexBot IRC Bot",
    "channels": ["#hexbot", { "name": "#secret", "key": "channel-key-here" }]
  },
  "owner": {
    "handle": "admin",
    "hostmask": "*!yourident@your.host.here"
  },
  "identity": {
    "method": "hostmask",
    "require_acc_for": ["+o", "+n"]
  },
  "services": {
    "type": "anope",
    "nickserv": "NickServ",
    "password_env": "NICKSERV_PASSWORD",
    "sasl": true,
    "sasl_mechanism": "PLAIN"
  },
  "database": "./data/hexbot.db",
  "pluginDir": "./plugins",
  "logging": {
    "level": "info",
    "mod_actions": true
  },
  "queue": {
    "rate": 1,
    "burst": 5
  },
  "flood": {
    "pub": { "count": 5, "window": 10 },
    "msg": { "count": 5, "window": 10 }
  },
  "dcc": {
    "enabled": false,
    "ip": "0.0.0.0",
    "port_range": [49152, 49171],
    "require_flags": "m",
    "max_sessions": 5,
    "idle_timeout_ms": 300000,
    "nickserv_verify": false
  },
  "proxy": {
    "enabled": false,
    "host": "127.0.0.1",
    "port": 9050,
    "password_env": "PROXY_PASSWORD"
  },
  "botlink": {
    "enabled": false,
    "role": "leaf",
    "botname": "mybot",
    "hub": {
      "host": "192.168.1.10",
      "port": 5051
    },
    "listen": {
      "host": "0.0.0.0",
      "port": 5051
    },
    "password_env": "BOTLINK_PASSWORD",
    "reconnect_delay_ms": 5000,
    "reconnect_max_delay_ms": 60000,
    "max_leaves": 10,
    "sync_permissions": true,
    "sync_channel_state": true,
    "sync_bans": true,
    "ping_interval_ms": 30000,
    "link_timeout_ms": 90000
  },
  "chanmod": {
    "nick_recovery_password_env": "CHANMOD_RECOVERY_PASSWORD"
  },
  "quit_message": "HexBot",
  "channel_rejoin_interval_ms": 30000
}
