{
  "irc": {
    "host": "irc.rizon.net",
    "port": 6697,
    "tls": true,
    "nick": "HexBot",
    "alt_nick": "HexBot^",
    "username": "hexbot",
    "realname": "HexBot IRC Bot",
    "channels": ["#hexbot"],
    "ghost_on_recover": true
  },
  "owner": {
    "password_env": "HEX_OWNER_PASSWORD"
  },
  "identity": {
    "method": "hostmask",
    "require_acc_for": ["+o", "+n"]
  },
  "services": {
    "type": "anope",
    "nickserv": "NickServ",
    "password_env": "HEX_NICKSERV_PASSWORD",
    "sasl": true,
    "sasl_mechanism": "PLAIN",
    "identify_before_join": true,
    "identify_before_join_timeout_ms": 10000
  },
  "logging": {
    "level": "info",
    "mod_actions": true
  },
  "chanmod": {
    "nick_recovery_password_env": "HEX_CHANMOD_RECOVERY_PASSWORD"
  }
}
