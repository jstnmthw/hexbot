# HexBot environment variables — template.
# Copy to config/bot.env and chmod 600:
#   cp config/bot.env.example config/bot.env && chmod 600 config/bot.env
#
# `pnpm start` and `pnpm dev` auto-load config/bot.env (via
# --env-file-if-exists=config/bot.env). For multi-instance setups, bypass
# the pnpm scripts and invoke tsx directly with a per-bot env file:
#   tsx --env-file=config/libera/chanbot.env src/index.ts --config=config/libera/chanbot.json
#
# Every secret referenced by config/bot.json lives here (see the *_env fields
# in bot.json). Each variable name below maps to a *_env field in bot.json —
# change the var name on both sides if you want a different name.

# Required when services.sasl is true and sasl_mechanism != "EXTERNAL".
NICKSERV_PASSWORD=

# Required when botlink.enabled is true.
BOTLINK_PASSWORD=

# Required when chanmod plugin uses NickServ GHOST for nick recovery.
CHANMOD_RECOVERY_PASSWORD=

# Required when proxy.enabled is true and proxy.username is set.
PROXY_PASSWORD=

# Channel +k keys are low-sensitivity operational tokens and are inlined
# in bot.json by default. If you prefer to keep them out of the config,
# add a key_env field on the channel entry and define the var here:
# CHANNEL_KEY_PARANOID=

# AI chat plugin — Gemini API key (free tier: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-api-key-here
