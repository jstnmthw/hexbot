# HexBot environment variables — template.
# Copy to config/bot.env and chmod 600:
#   cp config/bot.env.example config/bot.env && chmod 600 config/bot.env
#
# `pnpm start` and `pnpm dev` auto-load config/bot.env (via
# --env-file-if-exists=config/bot.env). For multi-instance setups, bypass
# the pnpm scripts and invoke tsx directly with a per-bot env file:
#   tsx --env-file=config/libera/chanbot.env src/index.ts --config=config/libera/chanbot.json
#
# Every secret referenced by config/bot.json lives here (see the *_env fields
# in bot.json). Each variable name below maps to a *_env field in bot.json —
# change the var name on both sides if you want a different name. The HEX_
# prefix namespaces these vars so they won't collide with other services
# on the host.

# -----------------------------------------------------------------------------
# Bootstrap (required at every boot — read by src/bootstrap.ts before bot.json
# is parsed; these values must be available before the SQLite KV is opened):
# -----------------------------------------------------------------------------

# Path to the SQLite database file. Created on first start.
HEX_DB_PATH='./data/hexbot.db'

# Path to the plugin directory. Each subdirectory is a plugin.
HEX_PLUGIN_DIR='./plugins'

# Initial owner identity. Consumed only on first boot to seed the owner
# user record; after that the DB is the store of record (`.chhost` /
# `.deluser` rotations from REPL/DCC persist across restarts).
HEX_OWNER_HANDLE='admin'
HEX_OWNER_HOSTMASK='*!yourident@your.host.here'

# -----------------------------------------------------------------------------
# Secrets (resolved via *_env fields in bot.json):
# -----------------------------------------------------------------------------

# Seed password for the owner's DCC CHAT account. Consumed only on first
# boot when the DB has no password hash for the configured owner — after
# that the DB is the store of record, and `.chpass` rotations from DCC/REPL
# persist across restarts (same lifecycle as MYSQL_ROOT_PASSWORD). Leave
# this set; to force a re-seed, clear the owner's stored hash and restart.
HEX_OWNER_PASSWORD=

# Required when services.sasl is true and sasl_mechanism != "EXTERNAL".
HEX_NICKSERV_PASSWORD=

# Required when botlink.enabled is true.
HEX_BOTLINK_PASSWORD=

# Required when chanmod plugin uses NickServ GHOST for nick recovery.
HEX_CHANMOD_RECOVERY_PASSWORD=

# Required when proxy.enabled is true and proxy.username is set.
HEX_PROXY_PASSWORD=

# Channel +k keys are low-sensitivity operational tokens and are inlined
# in bot.json by default. If you prefer to keep them out of the config,
# add a key_env field on the channel entry and define the var here:
# HEX_CHANNEL_KEY_PARANOID=

# AI chat plugin — Gemini API key (free tier: https://aistudio.google.com/apikey)
HEX_GEMINI_API_KEY='your-api-key-here'

# Spotify radio plugin — Spotify Web API credentials.
# Required only if the spotify-radio plugin is enabled.
# Obtain by registering an app at https://developer.spotify.com/dashboard,
# adding http://127.0.0.1:8888/callback as a redirect URI, then running
# `pnpm run spotify:auth` on your workstation (NOT inside the container).
# The refresh token must belong to the Spotify account that will be hosting
# the Jam and playing music — not the bot operator's account if those differ.
HEX_SPOTIFY_CLIENT_ID=
HEX_SPOTIFY_CLIENT_SECRET=
HEX_SPOTIFY_REFRESH_TOKEN=
