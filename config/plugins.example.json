{
  "chanmod": {
    "config": {
      "services_host_pattern": "services.*"
    }
  },
  "rss": {
    "enabled": false,
    "config": {
      "feeds": [
        {
          "id": "hackernews",
          "url": "https://news.ycombinator.com/rss",
          "name": "Hacker News",
          "channels": ["#tech"],
          "interval": 900
        }
      ]
    }
  },
  "ai-chat": {
    "enabled": false,
    "channels": ["#mychannel"],
    "config": {
      "provider": "gemini",
      "api_key_env": "HEX_GEMINI_API_KEY",
      "model": "gemini-2.5-flash-lite"
    }
  }
}
