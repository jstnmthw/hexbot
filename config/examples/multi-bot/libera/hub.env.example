# Libera hub bot — env file template.
# Copy to config/libera/hub.env (or wherever suits you) and chmod 600.

# Bootstrap (read by src/bootstrap.ts before bot.json is parsed).
HEX_DB_PATH=./data/libera-hub.db
HEX_PLUGIN_DIR=./plugins
HEX_OWNER_HANDLE=admin
HEX_OWNER_HOSTMASK=*!yourident@your.host.here

# NickServ / SASL password for Libera-Chanbot
HEX_NICKSERV_PASSWORD=

# Shared secret between hub and leaves for botlink authentication
HEX_BOTLINK_PASSWORD=

# NickServ GHOST password for nick recovery (chanmod plugin)
HEX_CHANMOD_RECOVERY_PASSWORD=
