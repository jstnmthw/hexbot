# Rizon leaf bot — env file template.
# Copy to config/rizon/leaf.env (or wherever suits you) and chmod 600.

# Bootstrap (read by src/bootstrap.ts before bot.json is parsed).
HEX_DB_PATH=./data/rizon-leaf.db
HEX_PLUGIN_DIR=./plugins
HEX_OWNER_HANDLE=admin
HEX_OWNER_HOSTMASK=*!yourident@your.host.here

# NickServ / SASL password for Rizon-Helper
HEX_NICKSERV_PASSWORD=

# Shared secret (must match the hub's HEX_BOTLINK_PASSWORD)
HEX_BOTLINK_PASSWORD=
